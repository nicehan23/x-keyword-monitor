# X (Twitter) API — https://developer.x.com 에서 발급
X_BEARER_TOKEN=여기에_Bearer_Token_입력
X_API_KEY=여기에_API_Key_입력
X_API_SECRET=여기에_API_Secret_입력
X_ACCESS_TOKEN=여기에_Access_Token_입력
X_ACCESS_TOKEN_SECRET=여기에_Access_Token_Secret_입력

# Claude API — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=여기에_Claude_API_Key_입력

# Supabase — https://supabase.com 에서 프로젝트 생성 후 발급
SUPABASE_URL=여기에_Supabase_URL_입력
SUPABASE_KEY=여기에_Supabase_Anon_Key_입력

# X 계정명 (자기 트윗 수집 제외용, 선택사항)
X_USERNAME=여기에_본인_X계정명
